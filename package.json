{
  "private": true,
  "name": "blog",
  "description": "Repo which lives at its name",
  "version": "0.0.1",
  "author": {
    "name": "Saurav Khdoolia",
    "email": "me@ksorv.com",
    "url": "https://ksorv.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ksorv/blog.git"
  },
  "browserslist": [
    "> 0.5%",
    "last 2 versions",
    "Firefox ESR",
    "not dead",
    "not IE 11"
  ],
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "sideEffects": false,
  "lint-staged": {
    "*.ts": "eslint --cache --fix",
    "*.tsx": "eslint --cache --fix"
  },
  "scripts": {
    "prepare": "husky install",
    "generate:css": "tailwindcss -i ./app/styles/tailwindIn.css -o ./app/styles/tailwindOut.css",
    "dev:remix": "cross-env NODE_ENV=development remix dev",
    "dev:css": "npm run generate:css -- --watch",
    "dev": "remix build && concurrently --kill-others --names 'REMIX,CSS' -c 'cyan.bold,blue.bold' \"npm run dev:remix\" \"npm run dev:css\"",
    "build:remix": "remix build",
    "build:css": "npm run generate:css -- --minify",
    "build": "npm run build:css && npm run build:remix",
    "start": "remix-serve build",
    "format": "prettier --write .",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "storybook": "cross-env TS_NODE_PROJECT=.storybook/tsconfig.json start-storybook -p 3002",
    "build-storybook": "build-storybook",
    "postinstall": "remix setup node",
    "deploy": "fly deploy --remote-only"
  },
  "dependencies": {
    "@remix-run/node": "1.7.3",
    "@remix-run/react": "1.7.3",
    "@remix-run/serve": "1.7.3",
    "classnames": "2.3.2",
    "framer-motion": "^7.6.1",
    "isbot": "3.5.4",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "recoil": "0.7.5",
    "remark-mdx-frontmatter": "1.1.1"
  },
  "devDependencies": {
    "@remix-run/dev": "^1.7.3",
    "@remix-run/eslint-config": "1.7.3",
    "@tailwindcss/typography": "0.5.0",
    "@types/node": "18.11.4",
    "@types/react": "18.0.15",
    "@types/react-dom": "18.0.6",
    "@types/tailwindcss": "2.2.4",
    "@typescript-eslint/eslint-plugin": "5.7.0",
    "@typescript-eslint/parser": "5.7.0",
    "autoprefixer": "10.4.11",
    "concurrently": "6.4.0",
    "cross-env": "^7.0.3",
    "eslint": "8.26.0",
    "eslint-config-airbnb": "19.0.2",
    "eslint-config-airbnb-typescript": "16.1.0",
    "eslint-config-prettier": "8.3.0",
    "eslint-import-resolver-typescript": "2.5.0",
    "eslint-plugin-import": "2.25.3",
    "eslint-plugin-jsx-a11y": "6.5.1",
    "eslint-plugin-prettier": "4.0.0",
    "eslint-plugin-react": "7.27.1",
    "eslint-plugin-react-hooks": "4.3.0",
    "eslint-plugin-storybook": "0.6.4",
    "husky": ">=6",
    "lint-staged": ">=10",
    "mdx-bundler": "9.0.1",
    "postcss": "8.4.16",
    "prettier": "2.5.1",
    "prettier-plugin-tailwindcss": "0.1.13",
    "tailwindcss": "3.0.6",
    "typescript": "4.8.4"
  }
}
